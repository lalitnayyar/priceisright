  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#ff6b35"
  style.font-color: "#ffb59d"
  style.bold: true
}

frontier: "Agent 2\nFrontier" {
  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#4ECDC4"
  style.font-color: "#5dd9d0"
  style.bold: true
}

specialist: "Agent 3\nSpecialist" {
  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#0969DA"
  style.font-color: "#adc6ff"
  style.bold: true
}

dnn: "Agent 4\nNeural Net" {
  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#5dd9d0"
  style.font-color: "#5dd9d0"
  style.bold: true
}

ensemble: "Agent 5\nEnsemble" {
  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#ff6b35"
  style.font-color: "#ffb59d"
  style.bold: true
}

messaging: "Agent 6\nMessaging" {
  shape: rectangle
  style.fill: "#2a1c18"
  style.stroke: "#F85149"
  style.font-color: "#ffb4ab"
  style.bold: true
}

