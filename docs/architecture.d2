direction: right

title: {
  label: "The Price Is Right — 7-Agent AI Pipeline"
  near: top-center
  style.font-size: 20
  style.bold: true
}

rss: "📡 RSS Feeds" {
  shape: cylinder
  style.fill: "#261814"
  style.stroke: "#ff6b35"
  style.font-color: "#f7ddd5"
}

